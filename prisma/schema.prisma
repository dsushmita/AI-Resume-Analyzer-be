generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum AnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// The tenant. Every piece of business data hangs off an Organization.
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]
  resumes     Resume[]
  analyses    Analysis[]
}

// A person. Identity only — what they may do lives on Membership.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
  resumes       Resume[]
  analyses      Analysis[]
}

// Links a user to an organization and carries their role in that specific org
model Membership {
  id             String   @id @default(cuid())
  role           Role     @default(MEMBER)
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// A pending employee invite. Only the hash of the token is stored.
model Invitation {
  id             String           @id @default(cuid())
  email          String
  role           Role             @default(MEMBER)
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  organizationId String
  invitedById    String?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

// Hashed refresh tokens, enabling rotation and revocation on logout
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resume {
  id             String   @id @default(cuid())
  title          String
  filePath       String // Cloudinary public_id / relative path, never an absolute local path
  fileType       String
  extractedText  String   @db.Text
  organizationId String
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses     Analysis[]

  @@index([organizationId])
  @@index([userId])
}

model Analysis {
  id                 String         @id @default(cuid())
  jobDescription     String         @db.Text
  status             AnalysisStatus @default(QUEUED)
  atsScore           Int?
  matchingSkills     Json?
  missingSkills      Json?
  strengths          Json?
  weaknesses         Json?
  suggestions        Json?
  interviewQuestions Json?
  error              String?
  resumeId           String
  organizationId     String
  userId             String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  resume       Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([resumeId])
  @@index([userId])
}

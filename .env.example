# Template for .env — safe to commit. Copy to .env and fill in real values.

NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/resume_analyzer?schema=public
REDIS_URL=redis://localhost:6380

# Auth
JWT_ACCESS_SECRET=generate-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=generate-with-openssl-rand-base64-48
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
